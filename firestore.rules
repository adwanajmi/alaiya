rules_version = '2';

service cloud.firestore {
	match /databases/{database}/documents {
		function signedIn() {
			return request.auth != null;
		}

		function isSelf(uid) {
			return signedIn() && request.auth.uid == uid;
		}

		function userDoc(uid) {
			return get(/databases/$(database)/documents/users/$(uid));
		}

		function isSuperAdmin() {
			return signedIn()
				&& exists(/databases/$(database)/documents/users/$(request.auth.uid))
				&& userDoc(request.auth.uid).data.platformRole == "SUPER_ADMIN";
		}

		function memberDoc(familyId, uid) {
			return get(/databases/$(database)/documents/family_members/$(familyId + "_" + uid));
		}

		function isFamilyMember(familyId) {
			return signedIn()
				&& exists(/databases/$(database)/documents/family_members/$(familyId + "_" + request.auth.uid))
				&& memberDoc(familyId, request.auth.uid).data.status == "active";
		}

		function familyRole(familyId) {
			return memberDoc(familyId, request.auth.uid).data.role;
		}

		function isFamilyParent(familyId) {
			return isSuperAdmin()
				|| (isFamilyMember(familyId) && familyRole(familyId) == "parent");
		}

		match /users/{uid} {
			allow create: if isSelf(uid)
				&& !("platformRole" in request.resource.data);
			allow read: if isSelf(uid) || isSuperAdmin();
			allow update: if isSelf(uid)
				&& request.resource.data.platformRole == resource.data.platformRole;
			allow delete: if isSuperAdmin();
		}

		match /invite_codes/{code} {
			allow get: if signedIn();
			allow list: if false;
			allow create, update: if signedIn()
				&& request.resource.data.familyId is string
				&& (
					request.resource.data.createdBy == request.auth.uid
					|| isFamilyParent(request.resource.data.familyId)
				);
			allow delete: if signedIn()
				&& isFamilyParent(resource.data.familyId);
		}

		match /families/{familyId} {
			allow create: if signedIn()
				&& request.resource.data.createdBy == request.auth.uid;
			allow read: if isFamilyMember(familyId) || isSuperAdmin();
			allow update: if isFamilyParent(familyId);
			allow delete: if isSuperAdmin();
		}

		match /family_members/{memberId} {
			allow create: if signedIn()
				&& request.resource.data.userId == request.auth.uid
				&& request.resource.data.familyId is string;
			allow read: if isFamilyMember(resource.data.familyId) || isSuperAdmin();
			allow update: if isFamilyParent(resource.data.familyId) || request.resource.data.userId == request.auth.uid;
			allow delete: if isFamilyParent(resource.data.familyId) || resource.data.userId == request.auth.uid;
		}

		match /babies/{babyId} {
			allow read: if isFamilyMember(resource.data.familyId) || isSuperAdmin();
			allow create: if isFamilyParent(request.resource.data.familyId)
				&& request.resource.data.familyId is string;
			allow update: if isFamilyMember(resource.data.familyId) || isSuperAdmin();
			allow delete: if isFamilyParent(resource.data.familyId);
		}

		match /logs/{logId} {
			allow read: if isFamilyMember(resource.data.familyId) || isSuperAdmin();
			allow create: if isFamilyMember(request.resource.data.familyId)
				&& request.resource.data.userId == request.auth.uid;
			allow update, delete: if isFamilyParent(resource.data.familyId)
				|| resource.data.userId == request.auth.uid;
		}

		match /growth/{growthId} {
			allow read: if isFamilyMember(resource.data.familyId) || isSuperAdmin();
			allow create: if isFamilyMember(request.resource.data.familyId)
				&& request.resource.data.userId == request.auth.uid;
			allow update, delete: if isFamilyParent(resource.data.familyId);
		}

		match /{document=**} {
			allow read, write: if false;
		}
	}
}
